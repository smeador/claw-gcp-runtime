{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-lab.local/openclaw.runtime-secrets.schema.json",
  "title": "OpenClaw Runtime Secrets Payload",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "auth": {
      "type": "object",
      "description": "Sensitive OpenClaw provider or integration authentication config merged into the runtime config."
    },
    "gateway": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "auth": {
          "type": "object",
          "description": "Sensitive gateway authentication config merged into gateway.auth."
        }
      },
      "required": [
        "auth"
      ]
    }
  },
  "required": [
    "auth",
    "gateway"
  ]
}
