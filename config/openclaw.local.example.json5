{
  "agents": {
    "defaults": {
      "model": {
        "primary": "openrouter/openai/gpt-5.4"
      },
      "workspace": "/absolute/path/to/gcp-claw-lab/workspace",
      "compaction": {
        "mode": "safeguard"
      },
      "maxConcurrent": 4,
      "subagents": {
        "maxConcurrent": 8
      }
    }
  },
  "messages": {
    "ackReactionScope": "group-mentions"
  },
  "commands": {
    "native": "auto",
    "nativeSkills": "auto",
    "restart": true,
    "ownerDisplay": "raw"
  },
  "tools": {
    "exec": {
      "host": "gateway",
      "security": "full",
      "ask": "off"
    }
  },
  "plugins": {
    "allow": [
      "browser",
      "device-pair",
      "document-extract",
      "file-transfer",
      "memory-core",
      "openrouter",
      "telegram",
      "web-readability"
    ],
    "entries": {
      "browser": { "enabled": true },
      "device-pair": { "enabled": true },
      "document-extract": { "enabled": true },
      "file-transfer": { "enabled": true },
      "memory-core": { "enabled": true },
      "openrouter": { "enabled": true },
      "telegram": { "enabled": true },
      "web-readability": { "enabled": true }
    },
    "bundledDiscovery": "allowlist"
  },
  "session": {
    "dmScope": "per-channel-peer"
  },
  "channels": {
    "telegram": {
      "enabled": false,
      "dmPolicy": "pairing",
      "groupPolicy": "disabled",
      "configWrites": false
    }
  },
  "hooks": {
    "internal": {
      "enabled": true,
      "entries": {
        "boot-md": {
          "enabled": false
        },
        "bootstrap-extra-files": {
          "enabled": true
        },
        "command-logger": {
          "enabled": true
        },
        "session-memory": {
          "enabled": true
        }
      }
    }
  },
  "gateway": {
    "mode": "local",
    "port": 18789,
    "bind": "loopback",
    "tailscale": {
      "mode": "off",
      "resetOnExit": false
    },
    "nodes": {
      "denyCommands": [
        "camera.snap",
        "camera.clip",
        "screen.record",
        "calendar.add",
        "contacts.add",
        "reminders.add"
      ]
    }
  }
}
