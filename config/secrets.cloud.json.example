{
  "$schema": "./openclaw.runtime-secrets.schema.json",
  "auth": {
    "profiles": {
      "openai:default": {
        "provider": "openai",
        "mode": "api_key"
      }
    }
  },
  "channels": {
    "telegram": {
      "enabled": false,
      "botToken": "REPLACE_WITH_A_TELEGRAM_BOT_TOKEN_IF_ENABLING_TELEGRAM"
    }
  },
  "gateway": {
    "auth": {
      "mode": "token",
      "token": "REPLACE_WITH_A_CLOUD_SPECIFIC_TOKEN"
    }
  }
}
