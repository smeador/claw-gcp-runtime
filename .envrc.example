# Runtime operator defaults for this repo.
# Keep repo-wide defaults here and put local overrides in .envrc.local.

source_env_if_exists .envrc.local
PATH_add bin

export VM_NAME=
export PROJECT_ID=
export ZONE=
export OPENCLAW_SECRET_NAME=

# Optional overrides.
export CLOUD_SECRET_FILE=
export GMAIL_TEST_TO=
# export GMAIL_TEST_SUBJECT="Pip Cloud Gmail send test"
# export DIGEST_MESSAGE="Run newsletter-digest now in test mode."
# export TAIL_LINES=200
