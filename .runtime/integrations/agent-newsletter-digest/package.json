{
  "name": "agent-newsletter-digest",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "bin": {
    "agent-newsletter-digest-extract": "./scripts/email/extract-newsletter-from-gmail.mjs",
    "agent-newsletter-digest-render": "./scripts/email/render-newsletter-digest.mjs",
    "agent-newsletter-digest-finalize": "./scripts/email/finalize-newsletter-digest.sh",
    "agent-newsletter-digest-send": "./scripts/gmail/send-gog-digest.sh",
    "agent-newsletter-digest-openclaw-test": "./scripts/openclaw/run-skill-test.sh"
  },
  "dependencies": {
    "cheerio": "^1.1.2",
    "turndown": "^7.2.1"
  },
  "scripts": {
    "extract": "node scripts/email/extract-newsletter-from-gmail.mjs",
    "render": "node scripts/email/render-newsletter-digest.mjs",
    "finalize": "bash scripts/email/finalize-newsletter-digest.sh",
    "test:openclaw-skill": "bash scripts/openclaw/run-skill-test.sh",
    "check:extract": "node --check scripts/email/extract-newsletter-from-gmail.mjs",
    "check:render": "node --check scripts/email/render-newsletter-digest.mjs",
    "check:shell": "bash -n scripts/email/finalize-newsletter-digest.sh && bash -n scripts/gmail/send-gog-digest.sh && bash -n scripts/openclaw/run-skill-test.sh && bash -n workspace/skills/pip-newsletter-digest/TEST.sh"
  }
}
